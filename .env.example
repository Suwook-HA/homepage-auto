# Optional admin auth (recommended for production)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_SESSION_HOURS=24

# Optional security for /api/refresh
CRON_SECRET=change-me

# Optional local scheduler inside the Next.js process
ENABLE_LOCAL_SCHEDULER=false
SCHEDULER_INTERVAL_MINUTES=180

# Optional runtime data directory (use persistent volume path in production)
DATA_DIR=

# Optional API tokens for richer ranking
YOUTUBE_API_KEY=
GITHUB_TOKEN=

# Required for Vercel deployment: persists admin edits back to the repo
# Format: owner/repo  e.g. Suwook-HA/homepage-auto
GITHUB_REPO=

# Google Photos Picker OAuth config
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
